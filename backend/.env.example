# Copy to backend/.env and fill in values.

NODE_ENV=development
PORT=4000

# Supabase project settings (Project Settings -> API).
# SUPABASE_ANON_KEY is safe to expose in the frontend too; the service role
# key is NOT — it must only ever live in this backend's environment.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Arcjet site key from https://app.arcjet.com
ARCJET_KEY=

# Encrypts secrets at rest (Jira API tokens, GitHub PATs, GitHub webhook
# secrets). Base64 of 32 random bytes, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENC_KEY=

# Exact origin the frontend is served from (used for CORS + Origin-header
# CSRF checks + signup email redirect links). No trailing slash.
FRONTEND_ORIGIN=http://localhost:5173

# Cookie attributes for the session cookies this API issues.
# Leave COOKIE_DOMAIN unset for local dev (localhost). In production, set it
# to the registrable domain shared by the frontend and API, e.g. ".bankai.app",
# so the cookie is sent to both. COOKIE_SAMESITE=none is only needed if the
# frontend and API are on genuinely different sites (not just subdomains) —
# it forces Secure and requires HTTPS.
COOKIE_DOMAIN=
COOKIE_SAMESITE=lax

# Powers AI repo scanning. Get a key from https://aistudio.google.com/apikey.
# gemini-pro-latest / gemini-flash-latest are the safest model ids to use —
# fixed version ids (e.g. gemini-2.5-pro) can 404 with "no longer available
# to new users" depending on the API key's account, even when listed by the
# API's own ListModels endpoint.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-pro-latest

# File-filtering caps for a repo scan — keep Gemini call volume and latency
# bounded on large repos. Defaults shown; only set to override.
MAX_SCAN_FILES=400
MAX_SCAN_FILE_BYTES=200000
MAX_SCAN_TOTAL_BYTES=20000000

# Backs the repo-scan job queue. Required by both the API server (enqueues
# scans) and `npm run worker` (processes them). Defaults to a local Redis.
REDIS_URL=redis://localhost:6379

# Powers "Connect your GitHub account" (a per-user OAuth grant covering all
# the user's repos, alongside the per-project PAT flow). Register an OAuth
# App at https://github.com/settings/developers with callback URL
# {BACKEND_PUBLIC_URL or http://localhost:4000}/api/auth/github/callback.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
